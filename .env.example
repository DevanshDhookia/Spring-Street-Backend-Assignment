# ── For running backfill.py locally against the Docker database ──────────────
# Docker exposes Postgres on port 5433 (to avoid conflict with any local Postgres).
# Redis stays on the default 6379.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/prisma_factsheet
REDIS_URL=redis://localhost:6379/0

# ── Pipeline schedule ─────────────────────────────────────────────────────────
# Default: 10 PM ET on weekdays (6 hours after US market close).
# Change PIPELINE_TIMEZONE to Asia/Kolkata for Indian market hours.
PIPELINE_CRON=0 22 * * 1-5
PIPELINE_TIMEZONE=America/New_York

# ── Performance calculation ───────────────────────────────────────────────────
RISK_FREE_RATE=0.05

# ── Redis cache ───────────────────────────────────────────────────────────────
CACHE_TTL=86400

# ── Admin API token ───────────────────────────────────────────────────────────
# Change this to a strong secret before any real deployment.
ADMIN_TOKEN=changeme
