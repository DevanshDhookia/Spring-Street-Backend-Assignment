DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prisma_factsheet
REDIS_URL=redis://localhost:6379/0

# Pipeline schedule — cron expression (default: 10 PM ET on weekdays)
PIPELINE_CRON=0 22 * * 1-5
PIPELINE_TIMEZONE=America/New_York

# Risk-free rate used in Sharpe / Treynor (annual, decimal)
RISK_FREE_RATE=0.05

# Redis cache TTL in seconds
CACHE_TTL=86400

# Simple token for admin routes
ADMIN_TOKEN=changeme
